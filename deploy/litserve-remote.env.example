# Скопируйте в /opt/agent-lab/.env на ноде litserve и заполните.
# Удобнее сгенерировать из GitHub Actions (job deploy-litserve) или из deploy/firewall-main-platform-for-litserve-node.sh + ручной правки.

IMAGE=ghcr.io/zamb124/agent-lab:latest

# IP или DNS основного сервера с Docker Compose платформы (тот же хост, что secrets.SERVER_HOST в Deploy).
MAIN_PLATFORM_HOST=84.38.184.105
POSTGRES_PASSWORD=

DATABASE__SHARED_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_shared
DATABASE__FLOWS_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_agents
DATABASE__CRM_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_crm
DATABASE__SYNC_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_sync
DATABASE__RAG_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_rag
DATABASE__OFFICE_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_office
DATABASE__TRACING_URL=postgresql+asyncpg://platform_user:${POSTGRES_PASSWORD}@${MAIN_PLATFORM_HOST}:5432/platform_tracing
DATABASE__REDIS_URL=redis://${MAIN_PLATFORM_HOST}:6379/0
TASKS__BROKER_URL=redis://${MAIN_PLATFORM_HOST}:6379/1

AUTH__JWT_SECRET=
DEPLOYMENT_VERSION=

PROVIDER_LITSERVE__INFRA__BACKEND=flagllm
PROVIDER_LITSERVE__INFRA__MODEL_ID=BAAI/bge-reranker-v2-gemma
PROVIDER_LITSERVE__INFRA__EMBEDDING_MODEL_ID=BAAI/bge-m3
HF_TOKEN=
