// =============================================================================
// Grafana Alloy: автоматический сбор логов + приём OTLP трейсов
// =============================================================================

// --- Docker log collection ---------------------------------------------------
// Автоматически находит все agentlab_* контейнеры и читает их stdout.
// Сервисы платформы не знают про Alloy — просто пишут JSON в stdout.

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
  filter {
    name  = "name"
    values = ["agentlab_*"]
  }
}

discovery.relabel "docker_labels" {
  targets = discovery.docker.containers.targets

  // Извлекаем имя сервиса из имени контейнера: agentlab_crm → crm
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/?(agentlab_)?(.*)"
    target_label  = "service"
    replacement   = "$2"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_labels.output
  forward_to = [loki.process.json_logs.receiver]
}

// --- JSON parsing ------------------------------------------------------------
// Извлекаем level и service.name как Loki labels (low cardinality).
// trace_id, user_id и другие high-cardinality поля остаются в теле записи —
// ищутся через LogQL `| json | trace_id = "..."`.

loki.process "json_logs" {
  stage.json {
    expressions = {
      level = "level",
      svc   = "\"service.name\"",
    }
  }

  stage.labels {
    values = {
      level = "",
      svc   = "",
    }
  }

  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}

// --- OTLP traces receiver ----------------------------------------------------
// Приложения отправляют трейсы через OTel SDK → Alloy → Tempo.
// Endpoint задаётся через ENV OTEL_EXPORTER_OTLP_ENDPOINT в docker-compose.

otelcol.receiver.otlp "traces" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"
    tls {
      insecure = true
    }
  }
}
