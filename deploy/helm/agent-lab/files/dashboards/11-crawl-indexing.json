{
  "schemaVersion": 39,
  "uid": "crawl-indexing",
  "title": "Crawl / RuNet Indexing",
  "tags": [
    "crawl",
    "search",
    "runet",
    "indexing"
  ],
  "timezone": "utc",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": "search-worker",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "search-worker",
          "value": "search-worker"
        },
        "options": [
          {
            "selected": true,
            "text": "search-worker",
            "value": "search-worker"
          }
        ]
      },
      {
        "name": "crawl_profile",
        "type": "custom",
        "query": "runet_platform",
        "multi": false,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "runet_platform",
          "value": "runet_platform"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "URLs Indexed / Enriched / min",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({service=~\"$service\"} | json | message=\"crawl.url.outcome\" | crawl_profile_id=~\"$crawl_profile\" | crawl_outcome=\"indexed\" [2m])) * 60",
          "legendFormat": "indexed",
          "refId": "A",
          "queryType": "range"
        },
        {
          "expr": "sum(rate({service=~\"$service\"} | json | message=\"crawl.url.outcome\" | crawl_profile_id=~\"$crawl_profile\" | crawl_outcome=\"enriched\" [2m])) * 60",
          "legendFormat": "enriched",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "URLs Skipped / min",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({service=~\"$service\"} | json | message=\"crawl.url.outcome\" | crawl_profile_id=~\"$crawl_profile\" | crawl_outcome=\"skipped\" [2m])) * 60",
          "legendFormat": "{{service}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 3,
      "title": "URL / Enrichment Failure Rate %",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({service=~\"$service\"} | json | message=\"crawl.url.outcome\" | crawl_profile_id=~\"$crawl_profile\" | crawl_outcome=~\"failed|enrichment_failed\" [2m])) / (sum(rate({service=~\"$service\"} | json | message=\"crawl.url.outcome\" | crawl_profile_id=~\"$crawl_profile\" [2m])) + 1e-10) * 100",
          "legendFormat": "failure rate %",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Enrichment Success Rate %",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({service=~\"$service\"} | json | message=\"crawl.enrich.completed\" | crawl_profile_id=~\"$crawl_profile\" [2m])) / (sum(rate({service=~\"$service\"} | json | message=~\"crawl[.]enrich[.](completed|failed)\" | crawl_profile_id=~\"$crawl_profile\" [2m])) + 1e-10) * 100",
          "legendFormat": "success %",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Crawl TaskIQ Tasks / min",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\"} | json | message=\"task_started\" | task_name=~\"crawl_.*\" [2m])) * 60",
          "legendFormat": "task_started {{service}}",
          "refId": "A",
          "queryType": "range"
        },
        {
          "expr": "sum(rate({service=~\"$service\"} | json | message=\"crawl.enrich.completed\" | crawl_profile_id=~\"$crawl_profile\" [2m])) * 60",
          "legendFormat": "enrich completed",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Pending URLs (tick completed)",
      "description": "Последний snapshot pending backlog после tick. 0 — очередь пуста (норма при активном enrich).",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "max by (service) (last_over_time({service=~\"$service\"} | json | message=\"crawl.tick.completed\" | crawl_profile_id=~\"$crawl_profile\" | unwrap pending_urls [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
