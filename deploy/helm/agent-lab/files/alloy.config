// =============================================================================
// Grafana Alloy для Kubernetes: автосбор pod logs + приём OTLP трейсов.
// Запускается как DaemonSet на каждой ноде, читает /var/log/pods (kubelet) и
// размечает поток метками namespace/pod/container/service. Авторизация —
// ServiceAccount alloy с ClusterRole на чтение pods и нод.
// =============================================================================

// --- Pod log collection ------------------------------------------------------

discovery.kubernetes "pods" {
  role = "pod"
  selectors {
    role  = "pod"
    field = "spec.nodeName=" + sys.env("HOSTNAME")
  }
}

discovery.relabel "pods" {
  targets = discovery.kubernetes.pods.targets

  rule {
    source_labels = ["__meta_kubernetes_namespace"]
    target_label  = "namespace"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_container_name"]
    target_label  = "container"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app"]
    target_label  = "service"
  }
  rule {
    source_labels = ["__meta_kubernetes_pod_node_name"]
    target_label  = "node"
  }
}

loki.source.kubernetes "pods" {
  targets    = discovery.relabel.pods.output
  forward_to = [loki.process.json_logs.receiver]
}

// --- JSON parsing ------------------------------------------------------------
// Извлекаем level из тела лога как Loki label (low cardinality).
// service label уже выставлен в discovery.relabel из app=<name> метки пода.
// trace_id/user_id/request_id остаются в теле — достаются через `| json | field = "value"`.
loki.process "json_logs" {
  stage.json {
    expressions = {
      level = "level",
    }
  }

  stage.labels {
    values = {
      level = "",
    }
  }

  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = "http://loki.platform.svc.cluster.local:3100/loki/api/v1/push"
  }
}

// --- OTLP traces receiver ----------------------------------------------------
// Приложения пишут трейсы через OTel SDK на http://alloy:4317 (см. agentlab.appEnv).

otelcol.receiver.otlp "traces" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo.platform.svc.cluster.local:4317"
    tls {
      insecure = true
    }
  }
}
