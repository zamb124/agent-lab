{
  "service": {
    "name": "rag-worker",
    "version": "1.0.0"
  },
  "database": {
    "url": "${DATABASE__URL}",
    "redis_url": "${DATABASE__REDIS_URL}"
  },
  "tasks": {
    "broker_url": "${TASKS__BROKER_URL}"
  },
  "rag": {
    "enabled": true,
    "default_provider": "pgvector",
    "providers": {
      "pgvector": {
        "enabled": true,
        "db_url": "${DATABASE__URL}",
        "embedding_api_key": "${RAG__EMBEDDING_API_KEY}"
      }
    },
    "embedding": {
      "model": "baai/bge-m3",
      "dimension": 1024
    }
  },
  "logging": {
    "level": "INFO",
    "format": "json"
  }
}
