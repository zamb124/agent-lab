{
  "service_name": "rag",
  "database": {
    "url": "postgresql+asyncpg://platform_user:admin@localhost:5435/platform_db",
    "shared_url": "postgresql+asyncpg://platform_user:admin@localhost:5435/platform_db"
  },
  "server": {
    "name": "rag",
    "host": "0.0.0.0",
    "port": 8004,
    "debug": true,
    "cors_origins": ["*"]
  },
  "auth": {
    "jwt_secret": "YOUR_JWT_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "session_secret": "YOUR_SESSION_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "jwt_algorithm": "HS256",
    "access_token_expire_minutes": 420,
    "refresh_token_expire_days": 7,
    "permissions_enabled": true
  },
  "logging": {
    "level": "INFO",
    "log_dir": "logs",
    "max_bytes": 10485760,
    "backup_count": 5,
    "truncate_limit": 1000
  },
  "rag": {
    "enabled": true,
    "default_provider": "pgvector",
    "embedding": {
      "model": "baai/bge-m3",
      "dimension": 1024
    },
    "providers": {
      "pgvector": {
        "enabled": true,
        "embedding_api_key": "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",
        "embedding_cost_per_1m_tokens": 5.0,
        "embedding_platform_markup": 1.1,
        "chunk_size": 1000,
        "chunk_overlap": 100,
        "timeout": 60
      },
      "agentset": {
        "enabled": true,
        "api_key": "agentset_MrUnHaYpdrNDCMeK",
        "embedding_api_key": "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",
        "embedding_cost_per_1m_tokens": 5.0,
        "embedding_platform_markup": 1.1,
        "base_url": "https://api.agentset.ai",
        "timeout": 60
      }
    }
  },
  "s3": {
    "enabled": true,
    "default_bucket": "files",
    "buckets": {
      "files": {
        "provider": "minio",
        "bucket_name": "files",
        "access_key_id": "minioadmin",
        "secret_access_key": "minioadmin",
        "region_name": "us-east-1",
        "endpoint_url": "http://localhost:9000",
        "enabled": true
      }
    }
  }
}

