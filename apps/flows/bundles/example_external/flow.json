{
  "flow_id": "example_external",
  "name": "Пример внешнего flow",
  "description": "Демонстрация интеграции с внешним (docker) flow по A2A с авторизацией через @var",
  "tags": [
    "example",
    "external",
    "a2a",
    "demo"
  ],
  "branches": {},
  "entry": "cat_facts",
  "nodes": {
    "cat_facts": {
      "type": "remote_flow",
      "url": "http://localhost:8002",
      "headers": {
        "X-API-Key": "@var:cat_flow_api_key"
      },
      "branch_id": "default"
    }
  },
  "variables": {
    "cat_flow_api_key": "cat-secret-key-12345"
  },
  "permission": [
    "admin",
    "developers"
  ],
  "edges": [
    {
      "from_node": "cat_facts",
      "to_node": null
    }
  ]
}
