{
  "flow_id": "example_react",
  "name": "Пример ReAct flow",
  "description": "Демонстрация ReAct: tools, subflow, interrupt, variables, skills; HITL — skills hitl_operator_react (тул hitl_operator_task) и hitl_operator_node (нода hitl_node), очередь example_hitl; Google Docs — skill google_docs",
  "tags": [
    "example",
    "react",
    "demo"
  ],
  "permission": [
    "admin",
    "developers"
  ],
  "entry": "main",
  "nodes": {
    "main": {
      "type": "llm_node",
      "node_id": "example_main_agent",
      "llm": {
        "provider": "humanitec_llm",
        "model": "auto",
        "temperature": 0.2
      }
    },
    "direct_subflow": {
      "type": "llm_node",
      "node_id": "example_subflow",
      "llm": {
        "provider": "humanitec_llm",
        "model": "auto",
        "temperature": 0.2
      }
    },
    "explicit_loop": {
      "type": "llm_node",
      "node_id": "explicit_finish_agent",
      "llm": {
        "provider": "humanitec_llm",
        "model": "auto",
        "temperature": 0.2
      }
    },
    "explicit_relaxed": {
      "type": "llm_node",
      "node_id": "explicit_relaxed_agent",
      "llm": {
        "provider": "humanitec_llm",
        "model": "auto",
        "temperature": 0.2
      }
    }
  },
  "edges": [
    {
      "from_node": "main",
      "to_node": null
    },
    {
      "from_node": "direct_subflow",
      "to_node": null
    },
    {
      "from_node": "explicit_loop",
      "to_node": null
    },
    {
      "from_node": "explicit_relaxed",
      "to_node": null
    }
  ],
  "variables": {
    "company_name": {
      "value": "@var:company_name",
      "public": true,
      "title": "Название компании",
      "description": "Название компании для использования в ответах flow"
    },
    "max_response_length": {
      "value": "500",
      "public": true,
      "title": "Максимальная длина ответа",
      "description": "Максимальное количество символов в ответе"
    },
    "support_contacts": {
      "value": "@var:support_contacts",
      "public": false
    }
  },
  "evaluation": {
    "contains_check": {
      "name": "contains",
      "description": "Проверка что ответ содержит слово",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Привет!"
          },
          "check": {
            "type": "string",
            "value": "contains:привет|здравствуй"
          }
        }
      ]
    },
    "not_contains_check": {
      "name": "not_contains",
      "description": "Проверка что ответ НЕ содержит слово",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Расскажи о погоде"
          },
          "check": {
            "type": "string",
            "value": "not_contains:ошибка|error"
          }
        }
      ]
    },
    "regex_check": {
      "name": "regex",
      "description": "Проверка регулярным выражением",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Сколько будет 2 + 2?"
          },
          "check": {
            "type": "string",
            "value": "regex:\\b4\\b"
          }
        }
      ]
    },
    "length_check": {
      "name": "length",
      "description": "Проверка длины ответа",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Привет"
          },
          "check": {
            "type": "string",
            "value": "length:10-500"
          }
        }
      ]
    },
    "length_range_check": {
      "name": "length range",
      "description": "Проверка длины ответа в диапазоне",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Привет"
          },
          "check": {
            "type": "string",
            "value": "length:10-500"
          }
        }
      ]
    },
    "state_equality_check": {
      "name": "state equality",
      "description": "Проверка равенства state",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Привет"
          },
          "check": {
            "type": "string",
            "value": "state:response!=null"
          }
        }
      ]
    },
    "function_check": {
      "name": "Python функция",
      "description": "Проверка через Python функцию",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Сколько будет 15 + 27?"
          },
          "check": {
            "type": "string",
            "value": "apps.flows.bundles.example_react.checks.check_calculator_result"
          }
        }
      ]
    },
    "inline_function": {
      "name": "Inline функции",
      "description": "Генератор и проверка через inline код",
      "turns": [
        {
          "input": {
            "type": "inline_code",
            "value": "async def generate():\n    return 'Тестовое сообщение'"
          },
          "check": {
            "type": "inline_code",
            "value": "async def check(state, response):\n    return len(response) > 5"
          }
        }
      ]
    },
    "multi_step": {
      "name": "Многошаговый диалог",
      "description": "Несколько шагов с проверками",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Привет!"
          },
          "check": {
            "type": "string",
            "value": "contains:привет|здравствуй"
          }
        },
        {
          "input": {
            "type": "text",
            "value": "Посчитай 10 + 5"
          },
          "check": {
            "type": "string",
            "value": "contains:15"
          }
        },
        {
          "input": {
            "type": "text",
            "value": "А теперь умножь на 2"
          },
          "check": {
            "type": "string",
            "value": "contains:30"
          }
        }
      ]
    },
    "flow_dialog_test": {
      "name": "Диалоговый тест (tester + judge)",
      "description": "Нода-тестер ведёт диалог, нода-судья оценивает",
      "max_turns": 5,
      "turns": [
        {
          "input": {
            "type": "node",
            "value": "evaluation_tester"
          },
          "check": {
            "type": "node",
            "value": "evaluation_judge"
          }
        }
      ]
    },
    "inline_flows": {
      "name": "Inline ноды (tester + judge)",
      "description": "Тестер и судья определены inline в evaluation",
      "max_turns": 3,
      "turns": [
        {
          "input": {
            "type": "node",
            "node": {
              "node_id": "evaluation_tester",
              "name": "Inline Tester",
              "prompt": "Ты тестер. Задай 2-3 вопроса агенту и заверши [TEST_COMPLETE]."
            }
          },
          "check": {
            "type": "node",
            "node": {
              "node_id": "evaluation_judge",
              "name": "Inline Judge",
              "prompt": "Оцени диалог. Верни JSON: {\"passed\": true, \"scores\": {\"quality\": 8}, \"feedback\": \"...\"}"
            }
          }
        }
      ]
    },
    "inline_flows_with_tools": {
      "name": "Inline ноды с tools",
      "description": "Тестер и судья с инструментами",
      "max_turns": 5,
      "turns": [
        {
          "input": {
            "type": "node",
            "node": {
              "node_id": "smart_tester",
              "name": "Smart Tester",
              "prompt": "Ты умный тестер. Используй калькулятор для проверки вычислений. Заверши [TEST_COMPLETE].",
              "tools": [
                {
                  "tool_id": "calculator",
                  "title": "Калькулятор"
                }
              ]
            }
          },
          "check": {
            "type": "node",
            "node": {
              "node_id": "smart_judge",
              "name": "Smart Judge",
              "prompt": "Оцени диалог. Проверь корректность ответов. Верни JSON: {\"passed\": true, \"scores\": {\"accuracy\": 9, \"helpfulness\": 8}, \"feedback\": \"...\"}",
              "tools": [
                {
                  "tool_id": "calculator",
                  "title": "Калькулятор"
                }
              ]
            }
          }
        }
      ]
    },
    "inline_function_with_state": {
      "name": "Inline функция со state",
      "description": "Генератор и проверка используют state",
      "turns": [
        {
          "input": {
            "type": "inline_code",
            "value": "async def generate():\n    import random\n    return f'Случайное число: {random.randint(1, 100)}'"
          },
          "check": {
            "type": "inline_code",
            "value": "async def check(state, response):\n    has_number = any(c.isdigit() for c in response)\n    return {'has_number': has_number, 'long_enough': len(response) > 10}"
          }
        }
      ]
    },
    "mixed_turns": {
      "name": "Смешанные типы",
      "description": "Разные типы input и check в одном тесте",
      "turns": [
        {
          "input": {
            "type": "text",
            "value": "Привет!"
          },
          "check": {
            "type": "string",
            "value": "contains:привет"
          }
        },
        {
          "input": {
            "type": "inline_code",
            "value": "async def generate():\n    return 'Сколько будет 5 * 5?'"
          },
          "check": {
            "type": "inline_code",
            "value": "async def check(s, r):\n    return '25' in r"
          }
        },
        {
          "input": {
            "type": "text",
            "value": "Спасибо за помощь!"
          },
          "check": {
            "type": "string",
            "value": "not_contains:ошибка"
          }
        }
      ]
    }
  },
  "branches": {
    "concise": {
      "name": "Краткие ответы",
      "description": "Режим коротких ответов для мобильных устройств",
      "variables": {
        "max_response_length": {
          "value": "200",
          "public": false
        }
      },
      "variables_mode": "merge"
    },
    "detailed": {
      "name": "Подробные ответы",
      "description": "Режим детальных ответов для десктопа",
      "variables": {
        "max_response_length": {
          "value": "2000",
          "public": false
        }
      },
      "variables_mode": "merge"
    },
    "no_subflow": {
      "name": "Без вложенного subflow",
      "description": "Режим без делегирования во вложенный flow",
      "nodes": {
        "main": {
          "type": "llm_node",
          "prompt": "prompts/main.md",
          "tools": [
            "calculator",
            "ask_user"
          ],
          "llm": {
            "model": "auto",
            "temperature": 0.3,
            "provider": "humanitec_llm"
          }
        }
      },
      "nodes_mode": "replace"
    },
    "direct_mode": {
      "name": "Прямой вход в subflow",
      "description": "Пропуск главной ноды, прямой вход в ноду вложенного subflow",
      "entry": "direct_subflow"
    },
    "explicit_mode": {
      "name": "Режим явного завершения (строгий)",
      "description": "Нода завершается ТОЛЬКО через finish tool. При тексте без finish - получает reminder.",
      "entry": "explicit_loop"
    },
    "explicit_relaxed_mode": {
      "name": "Режим явного завершения (нестрогий)",
      "description": "Желательно через finish, но текстовый ответ тоже принимается.",
      "entry": "explicit_relaxed"
    },
    "hitl_operator_react": {
      "name": "HITL: ReAct и тул hitl_operator_task",
      "description": "Агент с тулами calculator, ask_user и hitl_operator_task. Эскалация в очередь example_hitl. Триггеры: оператор, живой человек, эскалация, HITL.",
      "entry": "hitl_tool_main",
      "nodes": {
        "hitl_tool_main": {
          "type": "llm_node",
          "node_id": "example_hitl_tool_agent",
          "llm": {
            "provider": "humanitec_llm",
            "model": "auto",
            "temperature": 0.2
          }
        }
      },
      "nodes_mode": "merge",
      "edges": [
        {
          "from_node": "hitl_tool_main",
          "to_node": null
        }
      ],
      "edges_mode": "merge"
    },
    "hitl_operator_node": {
      "name": "HITL: нода hitl_node",
      "description": "Граф без LLM: code сохраняет примечание, hitl_node создаёт задачу в очереди example_hitl и прерывание до оператора.",
      "entry": "hitl_prepare",
      "nodes": {
        "hitl_prepare": {
          "type": "code",
          "code": "async def run(args, state):\n    c = str(state.get('content', '')).strip()\n    state['hitl_handoff_note'] = c[:500] if c else '(empty)'\n    return state"
        },
        "hitl_pause": {
          "type": "hitl_node",
          "operator_queue_slug": "example_hitl",
          "operator_task_title": "example_react: skill hitl_operator_node",
          "operator_user_message": "Запрос передан в демо-очередь операторов. Ожидайте ответа специалиста."
        }
      },
      "nodes_mode": "merge",
      "edges": [
        {
          "from_node": "hitl_prepare",
          "to_node": "hitl_pause"
        },
        {
          "from_node": "hitl_pause",
          "to_node": null
        }
      ],
      "edges_mode": "merge"
    },
    "google_docs": {
      "name": "Google Docs",
      "description": "Агент для работы с Google Docs: создание, чтение, редактирование, шаринг. Авторизация: переменные google_service_account (JSON SA) / google_access_token (Bearer-токен), или per-user OAuth.",
      "entry": "gdocs_main",
      "nodes": {
        "gdocs_main": {
          "type": "llm_node",
          "node_id": "example_gdocs_agent",
          "llm": {
            "provider": "humanitec_llm",
            "model": "auto",
            "temperature": 0.2
          }
        }
      },
      "nodes_mode": "merge",
      "edges": [
        {
          "from_node": "gdocs_main",
          "to_node": null
        }
      ],
      "edges_mode": "merge",
      "variables": {
        "google_service_account": {
          "value": "@var:google_service_account",
          "public": false,
          "title": "Google Service Account JSON",
          "description": "JSON ключ Service Account для Google API. Альтернатива: google_access_token."
        },
        "google_access_token": {
          "value": "@var:google_access_token",
          "public": false,
          "title": "Google OAuth2 Bearer-токен",
          "description": "Статичный access_token для Google API. Альтернатива: google_service_account."
        },
        "google_impersonate_email": {
          "value": "@var:google_impersonate_email",
          "public": false,
          "title": "Google Impersonate Email",
          "description": "Email для domain-wide delegation (только с Service Account)."
        }
      },
      "variables_mode": "merge"
    }
  }
}
