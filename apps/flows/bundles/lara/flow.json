{
  "id": "lara",
  "name": "Lara",
  "description": "Мультисервисный ассистент: навыки по сервисам (CRM — skill crm)",
  "version": "1.0.0",
  "tags": [
    "lara",
    "assistant",
    "multiservice",
    "crm",
    "flows"
  ],
  "permission": [
    "admin",
    "developers"
  ],
  "entry": "main",
  "nodes": {
    "main": {
      "type": "llm_node",
      "name": "Lara",
      "prompt": "prompts/base.md",
      "llm": {
        "model": "qwen/qwen3.5-397b-a17b",
        "temperature": 0.2
      },
      "tools": [
        "ask_user"
      ],
      "output_key": "response"
    }
  },
  "edges": [
    {
      "from": "main",
      "to": null
    }
  ],
  "variables": {
    "interface_language_code": "ru",
    "interface_language_name": "русском",
    "user_id": "",
    "user_name": "",
    "user_email": "",
    "user_first_name": "",
    "user_last_name": "",
    "company_id": "",
    "company_name": "",
    "active_namespace": "default",
    "user_language": "ru"
  },
  "branches": {
    "crm": {
      "name": "CRM NetWorkle",
      "description": "Lara для CRM: сущности, заметки, файлы, UI-блоки в чате",
      "tags": [
        "crm",
        "lara"
      ],
      "permission": [],
      "nodes_mode": "merge",
      "nodes": {
        "main": {
          "name": "Lara CRM",
          "prompt": "prompts/crm.md",
          "llm": {
            "model": "qwen/qwen3.5-397b-a17b",
            "temperature": 0.2
          },
          "tools": [
            "ask_user",
            "crm_search_entities",
            "crm_create_note",
            "crm_create_note_and_analyze",
            "crm_analyze_note_text",
            "create_file",
            "read_file",
            "push_embed_blocks"
          ],
          "output_key": "response"
        }
      }
    },
    "flows": {
      "name": "Flows Builder",
      "description": "Lara для работы с flow/skill/node и patch-изменениями редактора",
      "tags": [
        "flows",
        "lara"
      ],
      "permission": [],
      "nodes_mode": "merge",
      "nodes": {
        "main": {
          "name": "Lara Flows",
          "prompt": "prompts/flows.md",
          "llm": {
            "model": "qwen/qwen3.5-397b-a17b",
            "temperature": 0.2
          },
          "tools": [
            "ask_user",
            "flows_read_context",
            "flows_patch_node",
            "flows_patch_flow",
            "push_embed_blocks"
          ],
          "output_key": "response"
        }
      }
    }
  }
}
