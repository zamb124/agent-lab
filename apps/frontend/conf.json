{
  "service_name": "frontend",
  "database": {
    "url": "postgresql+asyncpg://platform_user:admin@localhost:5435/platform_db",
    "shared_url": "postgresql+asyncpg://platform_user:admin@localhost:5435/platform_db",
    "redis_url": "redis://localhost:6381/0"
  },
  "server": {
    "name": "frontend",
    "host": "0.0.0.0",
    "port": 8002,
    "debug": true,
    "cors_origins": ["*"]
  },
  "auth": {
    "jwt_secret": "YOUR_JWT_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "session_secret": "YOUR_SESSION_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "jwt_algorithm": "HS256",
    "access_token_expire_minutes": 420,
    "refresh_token_expire_days": 7,
    "permissions_enabled": false
  },
  "logging": {
    "level": "INFO",
    "log_dir": "logs",
    "max_bytes": 10485760,
    "backup_count": 5,
    "truncate_limit": 1000
  }
}
