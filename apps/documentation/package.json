{
  "name": "documentation",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare-content": "python3 ../../scripts/docs_prepare.py",
    "prebuild": "npm run prepare-content",
    "build": "next build",
    "predev": "npm run prepare-content",
    "dev": "next dev --port 3000",
    "start": "serve out",
    "types:check": "npx fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "npx fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.7.11",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.11",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.9",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}