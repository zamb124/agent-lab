{
  "id": "example_external",
  "name": "Пример внешнего агента",
  "description": "Демонстрация интеграции с внешним (docker) агентом по A2A протоколу с авторизацией через @var",
  "tags": [
    "example",
    "external",
    "a2a",
    "demo"
  ],
  "entry": "cat_facts",
  "nodes": {
    "cat_facts": {
      "type": "remote_agent",
      "url": "http://localhost:8002",
      "auth_headers": {
        "X-API-Key": "@var:cat_agent_api_key"
      },
      "skill_id": "default"
    }
  },
  "variables": {
    "cat_agent_api_key": "cat-secret-key-12345"
  },
  "permission": [
    "admin",
    "developers"
  ],
  "edges": [
    {
      "from": "cat_facts",
      "to": null
    }
  ]
}