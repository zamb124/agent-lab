{
  "service_name": "agents",
  "database": {
    "url": "postgresql+asyncpg://platform_user:admin@localhost:54321/platform_db",
    "shared_url": "postgresql+asyncpg://platform_user:admin@localhost:54321/platform_db",
    "redis_url": "redis://localhost:63791/0"
  },
  "server": {
    "name": "agents",
    "host": "0.0.0.0",
    "port": 8001,
    "debug": true,
    "cors_origins": ["*"]
  },
  "auth": {
    "jwt_secret": "YOUR_JWT_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "session_secret": "YOUR_SESSION_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "jwt_algorithm": "HS256",
    "access_token_expire_minutes": 420,
    "refresh_token_expire_days": 7,
    "permissions_enabled": false
  },
  "tasks": {
    "broker_url": "redis://localhost:63791/0"
  },
  "logging": {
    "level": "INFO",
    "log_dir": "logs",
    "max_bytes": 10485760,
    "backup_count": 5,
    "truncate_limit": 1000
  },
  "tracing": {
    "enabled": true,
    "postgres_enabled": true,
    "tempo_enabled": false,
    "service_name": "agents",
    "retention_days": 30
  },
  "llm": {
    "provider": "openrouter",
    "default_model": "anthropic/claude-sonnet-4.5",
    "vision_model": "google/gemini-2.5-pro",
    "temperature": 0.2,
    "timeout": 120,
    "openrouter": {
      "base_url": "https://openrouter.ai/api/v1",
      "site_url": "https://humanitec.ru",
      "site_name": "Humanitec"
    }
  },
  "s3": {
    "enabled": false,
    "default_bucket": "files",
    "endpoint_url": "YOUR_S3_ENDPOINT_URL",
    "access_key": "YOUR_S3_ACCESS_KEY",
    "secret_key": "YOUR_S3_SECRET_KEY",
    "region": "us-east-1"
  },
  "external_agents": {
    "agents": [],
    "health_check_interval": 60
  },
  "files": {
    "max_size_mb": 10,
    "allowed_extensions": [".txt", ".pdf", ".docx", ".png", ".jpg", ".jpeg"]
  },
  "mock": {
    "enabled": false
  },
  "push": {
    "enabled": false
  }
}

