{
  "database": {
    "office_url": "postgresql+asyncpg://platform_user:admin@localhost:54321/platform_office"
  },
  "server": {
    "env": "development",
    "platform_public_base_url": "http://system.lvh.me:8002",
    "document_server_dev_upstream_url": "http://localhost:8088"
  },
  "auth": {
    "jwt_secret_key": "YOUR_JWT_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "session_secret": "YOUR_SESSION_SECRET_KEY_CHANGE_IN_PRODUCTION",
    "providers": {
      "yandex": {
        "client_id": "YOUR_YANDEX_CLIENT_ID",
        "client_secret": "YOUR_YANDEX_CLIENT_SECRET"
      },
      "google": {
        "client_id": "YOUR_GOOGLE_CLIENT_ID",
        "client_secret": "YOUR_GOOGLE_CLIENT_SECRET"
      },
      "github": {
        "client_id": "YOUR_GITHUB_CLIENT_ID",
        "client_secret": "YOUR_GITHUB_CLIENT_SECRET"
      },
      "apple": {
        "client_id": "app.humanitec.ru",
        "apple_team_id": "YOUR_APPLE_TEAM_ID",
        "apple_key_id": "YOUR_APPLE_KEY_ID",
        "apple_private_key": "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
      }
    },
    "demo": {
      "login_enabled": true,
      "email": "demo@demo.ru",
      "password": "Zz123456",
      "company_id": "demo",
      "subdomain": "demo",
      "company_name": "Demo"
    }
  },
  "llm": {
    "openrouter": {
      "api_key": "YOUR_OPENROUTER_API_KEY"
    },
    "bothub": {
      "api_key": "YOUR_BOTHUB_API_KEY"
    },
    "groq": {
      "api_key": "YOUR_GROQ_API_KEY"
    },
    "google": {
      "api_key": "YOUR_GOOGLE_LLM_API_KEY"
    },
    "github": {
      "api_key": "YOUR_GITHUB_MODELS_API_KEY"
    },
    "huggingface": {
      "api_key": "YOUR_HUGGINGFACE_API_KEY"
    },
    "deepinfra": {
      "api_key": "YOUR_DEEPINFRA_API_KEY"
    },
    "model_scoring": {
      "seed_enabled": true,
      "force_seed_refresh": false
    }
  },
  "s3": {
    "default_bucket": "files",
    "buckets": {
      "test-bucket": {
        "provider": "minio",
        "bucket_name": "test-bucket",
        "access_key_id": "minioadmin",
        "secret_access_key": "minioadmin",
        "region_name": "us-east-1",
        "endpoint_url": "http://127.0.0.1:19001",
        "enabled": true
      },
      "files": {
        "provider": "minio",
        "bucket_name": "files",
        "access_key_id": "minioadmin",
        "secret_access_key": "minioadmin",
        "region_name": "us-east-1",
        "endpoint_url": "http://127.0.0.1:19001",
        "enabled": true
      },
      "secretbucket": {
        "access_key_id": "YOUR_YANDEX_S3_ACCESS_KEY_ID",
        "secret_access_key": "YOUR_YANDEX_S3_SECRET_ACCESS_KEY",
        "enabled": false
      },
      "vkbucket": {
        "access_key_id": "YOUR_VKCLOUD_S3_ACCESS_KEY_ID",
        "secret_access_key": "YOUR_VKCLOUD_S3_SECRET_ACCESS_KEY",
        "enabled": false
      }
    }
  },
  "proxy": {
    "proxies": [
      "http://YOUR_PROXY_USER:YOUR_PROXY_PASSWORD@YOUR_PROXY_HOST:YOUR_PROXY_PORT"
    ]
  },
  "voice": {
    "stt": {
      "provider": "litserve",
      "litserve": {
        "enabled": true,
        "base_url": "http://127.0.0.1:8014",
        "timeout_s": 120.0
      },
      "cloud_ru": {
        "enabled": false,
        "api_key": "YOUR_CLOUD_RU_STT_API_KEY",
        "base_url": "https://foundation-models.api.cloud.ru/v1/audio/transcriptions",
        "model": "openai/whisper-large-v3",
        "response_format": "text",
        "temperature": 0.5,
        "language": "ru",
        "timeout": 300.0
      }
    },
    "tts": {
      "provider": "litserve",
      "litserve": {
        "enabled": true,
        "base_url": "http://127.0.0.1:8014",
        "timeout_s": 120.0
      }
    }
  },
  "nano_banana": {
    "api_key": "YOUR_NANO_BANANA_API_KEY"
  },
  "payment_providers": {
    "providers": {
      "yoomoney_main": {
        "account_number": "YOUR_YOOMONEY_ACCOUNT_NUMBER",
        "notification_secret": "YOUR_YOOMONEY_NOTIFICATION_SECRET",
        "client_id": "YOUR_YOOMONEY_CLIENT_ID",
        "client_secret": "YOUR_YOOMONEY_CLIENT_SECRET"
      }
    }
  },
  "rag": {
    "providers": {
      "agentset": {
        "api_key": "YOUR_AGENTSET_API_KEY",
        "embedding_api_key": "YOUR_EMBEDDING_API_KEY",
        "base_url": "https://api.agentset.ai"
      }
    }
  },
  "push": {
    "enabled": true,
    "vapid_public_key": "YOUR_VAPID_PUBLIC_KEY",
    "vapid_private_key": "YOUR_VAPID_PRIVATE_KEY",
    "vapid_email": "YOUR_EMAIL@example.com",
    "apns_team_id": null,
    "apns_key_id": null,
    "apns_private_key": null,
    "apns_bundle_id": null,
    "apns_use_sandbox": false,
    "fcm_credentials_json": null,
    "fcm_project_id": null
  },
  "calendar_sync": {
    "sync_meeting_reminder_enabled": true,
    "sync_meeting_reminder_cron": "*/1 * * * *",
    "sync_meeting_reminder_limit": 500
  },
  "selectel": {
    "ip": "YOUR_SERVER_PUBLIC_IPV4",
    "login": "root",
    "ssh_port": "22"
  },
  "ingress": {
    "domain": "your-domain.example.com",
    "email": "admin@your-domain.example.com",
    "services": [
      {"name": "frontend", "port": 8002, "path": "/", "websocket": false},
      {"name": "agents", "port": 8001, "path": "/flows", "websocket": false},
      {"name": "crm", "port": 8003, "path": "/crm", "websocket": false},
      {"name": "rag", "port": 8004, "path": "/rag", "websocket": false},
      {"name": "sync", "port": 8005, "path": "/sync", "websocket": true},
      {"name": "office", "port": 8008, "path": "/documents", "websocket": false}
    ],
    "onlyoffice_port": 8088
  },
  "agent": {
    "releases": {
      "github_owner": "zamb124",
      "github_repo": "agent-lab"
    }
  },
  "services": {
    "office": {
      "office": {
        "document_server_public_url": "https://onlyoffice.your-domain.example.com",
        "jwt_secret": "YOUR_ONLYOFFICE_JWT_SAME_AS_DS",
        "callback_public_base_url": "http://localhost:8008",
        "download_token_ttl_seconds": 900
      }
    }
  }
}
