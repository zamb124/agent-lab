# GPU базовый образ платформы: Python 3.14 (GIL build), для сервисов с тяжёлыми
# ML/Audio-нативными расширениями, у которых ПОКА НЕТ cp314t wheels:
#   - torchaudio (silero_vad → import torchaudio): `_torchaudio.abi3.so` собран
#     для GIL CPython, не загружается в free-threaded интерпретатор (PEP 703).
#   - pyannote-audio, silero, transformers и прочее ML — стабильнее на 3.14 GIL.
#
# Главный платформенный image (Dockerfile / agent-lab-base) остаётся на 3.14t.
# Этот образ используется ТОЛЬКО для provider-litserve (и аналогичных GPU/ML
# сервисов, если появятся). Helm-чарт берёт его через `litserve.image`.
#
# Источник правды: `.github/workflows/build-base-gpu.yml` → push в
# ghcr.io/<owner>/agent-lab-base-gpu:latest|:<sha>.
#
# Когда пересобирать: при изменении ЛЮБОЙ зависимости в группах
# core / rag / rag-worker / agents / worker-base в pyproject.toml.

FROM ghcr.io/astral-sh/uv:bookworm-slim

WORKDIR /app

ARG NODE_MAJOR=24

# GIL build CPython 3.14: ABI совместима с published torchaudio/torch/pyannote wheels.
# PYTHON_GIL не задаём — default для GIL-build = 1 (GIL включён).
ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
ENV UV_PYTHON_PREFERENCE=only-managed

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    gnupg \
    build-essential \
    pkg-config \
    libcairo2-dev \
    libpq-dev \
    ffmpeg \
    tesseract-ocr \
    tesseract-ocr-rus \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    antiword \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# Rust toolchain нужен для PyO3-extensions без cp314 wheel (safetensors, tokenizers,
# tokie у chonkie 1.6+). На GIL-build часть уже есть wheels — но Rust оставляем
# на случай sdist-фолбэка.
ENV RUSTUP_HOME=/usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
ENV PATH="${CARGO_HOME}/bin:${PATH}"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal --no-modify-path \
    && rustc --version && cargo --version

RUN uv python install 3.14 && uv python pin 3.14

RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock README.md ./

# GIL venv для litserve и других ML-сервисов.
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="/opt/venv/bin:${PATH}"
ENV UV_HTTP_TIMEOUT=600
RUN uv venv --python 3.14 "${VIRTUAL_ENV}"

# Torch CPU (~2-3 GB меньше чем CUDA). GPU inference у нас идёт через
# nvidia-runtime + cuda-libraries прокидываемые с хоста (см. bootstrap-gpu-worker.sh
# и `litserve` resource nvidia.com/gpu). Если позже понадобится bundled CUDA-torch
# — заменить index-url на cu124 / соответствующий.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --python "${VIRTUAL_ENV}/bin/python" torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cpu

# Production deps платформы для GPU/ML-стороны: core + rag (litserve, silero,
# silero-vad, pyannote-audio, sentence-transformers, transformers, flagembedding,
# soundfile, hydra, omegaconf) + rag-worker (tiktoken, beautifulsoup4) +
# agents + worker-base (общие зависимости для process-supervisor / granian).
RUN --mount=type=cache,target=/root/.cache/uv \
    uv export --frozen --no-dev --no-default-groups \
        --group core \
        --group agents \
        --group worker-base \
        --group rag \
        --group rag-worker \
        --no-annotate --no-header --no-emit-project \
        -o /tmp/requirements.txt && \
    uv pip install --python "${VIRTUAL_ENV}/bin/python" -r /tmp/requirements.txt
