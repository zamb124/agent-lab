## Примеры tools

### Простой tool

```python
@tool(
    name="greet",
    description="Приветствует пользователя",
    tags=["greeting"]
)
async def greet(name: str) -> str:
    """Приветствует пользователя по имени."""
    return f"Привет, {name}!"
```

### Tool с state

```python
@tool(
    name="get_user_info",
    description="Получает информацию о текущем пользователе",
    tags=["user"]
)
async def get_user_info(state: "ExecutionState" = None) -> dict:
    """Получает информацию о пользователе из state."""
    if not state:
        return {"error": "State недоступен"}
    
    return {
        "user_id": state.user_id,
        "context_id": state.context_id,
        "session_id": state.session_id
    }
```

### Tool с API вызовом

```python
@tool(
    name="get_weather",
    description="Получает погоду в городе",
    tags=["weather", "api"],
    mock_response={"temp": 20, "condition": "sunny"}
)
async def get_weather(city: str) -> dict:
    """
    Получает погоду.
    
    Args:
        city: Название города
    """
    async with httpx.AsyncClient() as client:
        response = await client.get(
            "https://api.weather.com/forecast",
            params={"city": city}
        )
        return response.json()
```

### Tool с permissions

```python
@tool(
    name="view_analytics",
    description="Показывает аналитику (только для менеджеров)",
    tags=["analytics", "admin"],
    permission=["admin", "managers"]
)
async def view_analytics(period: str = "today") -> dict:
    """
    Показывает аналитику за период.
    
    Args:
        period: Период (today, week, month)
    """
    # Логика получения аналитики
    return {
        "period": period,
        "users": 1000,
        "revenue": 50000
    }
```

### Tool с обработкой ошибок

```python
@tool(
    name="fetch_data",
    description="Получает данные по URL",
    tags=["api"]
)
async def fetch_data(url: str) -> dict:
    """
    Получает данные.
    
    Args:
        url: URL для запроса
    """
    if not url.startswith("https://"):
        raise ValueError(f"Небезопасный URL: {url}")
    
    try:
        async with httpx.AsyncClient(timeout=30.0) as client:
            response = await client.get(url)
            response.raise_for_status()
            return response.json()
    except httpx.HTTPStatusError as e:
        raise ValueError(
            f"Ошибка HTTP {e.response.status_code}: {url}"
        ) from e
    except httpx.TimeoutException:
        raise ValueError(f"Timeout при запросе к {url}")
```

### Tool с вычислениями

```python
@tool(
    name="calculate",
    description="Вычисляет математическое выражение",
    tags=["math"],
    mock_response="42"
)
def calculate(expression: str) -> float:
    """
    Вычисляет выражение.
    
    Args:
        expression: Математическое выражение
    """
    import math
    
    # Безопасный eval с ограниченным контекстом
    allowed = {
        'sin': math.sin,
        'cos': math.cos,
        'tan': math.tan,
        'sqrt': math.sqrt,
        'pi': math.pi,
        'e': math.e,
    }
    
    try:
        result = eval(expression, {'__builtins__': {}}, allowed)
        return float(result)
    except Exception as e:
        raise ValueError(f"Ошибка вычисления: {e}")
```

