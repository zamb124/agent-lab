## Компоненты работают с ExecutionState

### Ноды

```python
class BaseNode(ABC):
    @abstractmethod
    async def run(self, state: ExecutionState) -> ExecutionState:
        pass
```

**ЗАПРЕЩЕНО:**
```python
# ❌ НЕ ТАК
state_dict = state.model_dump()
result_dict = await some_function(state_dict)
return ExecutionState.model_validate(result_dict)
```

**ПРАВИЛЬНО:**
```python
# ✅ ТАК
result_state = await some_function(state)
return result_state
```

### Tools

```python
class BaseTool(ABC):
    @abstractmethod
    async def execute(self, args: Dict[str, Any], state: ExecutionState) -> Any:
        pass
```

**Inline Tools через SafeEval:**
```python
class InlineTool(BaseTool):
    async def execute(self, args: Dict[str, Any], state: ExecutionState) -> Any:
        SafeEval = get_container().safe_eval_class
        evaluator = SafeEval(variables=state.variables)
        
        # Передаем ExecutionState напрямую в SafeEval
        result = await evaluator.execute_tool(self._code, args, state)
        return result
```

### SafeEval

```python
class SafeEval:
    async def execute_node(self, code: str, state: ExecutionState) -> ExecutionState:
        # Inline код работает с ExecutionState
        func = self._compile(code, "run", auto_find=True)
        
        if inspect.iscoroutinefunction(func):
            result = await func(state)
        else:
            result = func(state)
        
        # Если вернули dict - конвертируем в ExecutionState
        if isinstance(result, dict):
            return ExecutionState.model_validate(result)
        
        return result
    
    async def execute_tool(self, code: str, args: Dict[str, Any], state: ExecutionState) -> Any:
        # Tool inline код также работает с ExecutionState
        func = self._compile(code, "execute", auto_find=True)
        
        if "state" in inspect.signature(func).parameters:
            return await func(**args, state=state)
        return await func(**args)
```

### StateManager

```python
class StateManager:
    async def get_state(self, session_id: str) -> Optional[ExecutionState]:
        # Возвращает ExecutionState, не Dict!
        return await self._repository.get(session_id)
    
    async def save_state(self, session_id: str, state: ExecutionState) -> bool:
        # Принимает ExecutionState, не Dict!
        return await self._repository.set(session_id, state)
```

### MappingResolver

```python
class MappingResolver:
    @staticmethod
    def resolve_value(source: Any, state: ExecutionState) -> Any:
        if source.startswith("@state:"):
            path = source[7:]
            return MappingResolver.get_nested_value(state, path)
        if source.startswith("@var:"):
            var_path = source[5:]
            return MappingResolver.get_nested_value(state.variables, var_path)
        return source
    
    @staticmethod
    def get_nested_value(data: Any, path: str) -> Any:
        # Работает и с ExecutionState (через атрибуты), и с dict (через ключи)
        keys = path.split(".")
        value = data
        
        for key in keys:
            if hasattr(value, key):
                value = getattr(value, key)
            elif isinstance(value, dict):
                value = value.get(key)
            else:
                return None
        
        return value
```

### LLM Factory

```python
def get_llm_for_state(
    state: Optional[ExecutionState] = None,
    model_name: Optional[str] = None,
    temperature: Optional[float] = None,
) -> LLMClient | MockLLM:
    # Принимает ExecutionState для проверки mock конфигурации
    mock_config = get_mock_for_llm(state)
    if mock_config:
        return MockLLM.from_mock_config(mock_config)
    return get_llm(model_name, temperature)
```

### Mock Resolver

```python
def get_mock_for_tool(state: Optional[ExecutionState], tool_id: str) -> Optional[Any]:
    if not state or not state.mock or not state.mock.get("enabled"):
        return None
    tools = state.mock.get("tools", {})
    return tools.get(tool_id)
```

