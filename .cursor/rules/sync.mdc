    call_handlers.py     # звонки (invite/accept/decline/hangup/recording…)
    command_router.py    # SYNC_OPERATIONS реестр + register_sync_ws_commands() (один handler — два транспорта)
    presence_hooks.py    # connect/disconnect hooks для sync presence
    publish_events.py    # publish_realtime_events → core.ui_events.publish_ui_event_*
    tasks.py             # TaskIQ задачи (sync_transcribe_audio/video/call, sync_finalize_recording)
    notification_tasks.py # deliver_channel_message_notification, deliver_sync_mention_notification
  db/
    models.py       # SQLAlchemy модели (Base); миграции — migrations/sync/ (Alembic)
    base.py         # SyncDatabase + BaseSyncRepository
    repositories/   # Channel, Thread, Message, File, GitResourceRef, Call, Meeting
  models/           # Pydantic API-модели (Read/Create/Update)
  api/              # REST роутеры (namespaces, channels, messages, threads, calls, company, git)

apps/sync_worker/   # TaskIQ worker (queue: sync)
```

