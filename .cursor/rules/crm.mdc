## Модели данных

### crm_db (PostgreSQL)

```python
# apps/crm/db/models.py

class EntityType(Base):
    """Типы сущностей (person, organization, project + кастомные)"""
    type_id: str              # primary key
    company_id: Optional[str] # NULL для системных
    name: str
    required_attributes: List[str]
    optional_attributes: List[str]
    is_system: bool           # True для встроенных типов
    icon: str                 # Tabler icon name
    color: str                # Цвет для UI

class Relationship(Base):
    """Связи между сущностями"""
    relationship_id: str
    company_id: str
    source_entity_id: str     # ID в ChromaDB
    target_entity_id: str     # ID в ChromaDB
    relationship_type: str    # works_for, connected_to, etc.
    weight: float             # 0.0 - 1.0

class Note(Base):
    """Заметки (Daily Notes)"""
    note_id: str
    company_id: str
    user_id: str
    title: str
    content: str              # Markdown
    note_type: str            # freeform, meeting_minutes, call_log
    note_date: date
    ai_summary: Optional[str]
    linked_entity_ids: List[str]  # ID сущностей в ChromaDB
    attachment_ids: List[str]     # ID файлов в S3
    status: str               # draft, published, importing
    visibility: str           # public, private

class Task(Base):
    """Задачи"""
    task_id: str
    company_id: str
    user_id: str
    title: str
    priority: str             # low, medium, high, urgent
    status: str               # pending, in_progress, completed, cancelled
    due_date: Optional[date]
    linked_entity_id: Optional[str]
    source_note_id: Optional[str]
    assignees: List[str]      # user_ids соучастников

class AccessRequest(Base):
    """Запросы на доступ к скрытым ресурсам"""
    request_id: str
    requester_id: str
    owner_id: str
    resource_type: str        # note, entity
    resource_id: str
    status: str               # pending, approved, rejected

class UserProfile(Base):
    """Профиль пользователя в CRM"""
    profile_id: str
    user_id: str
    company_id: str
    display_name: str
    position: str
    avatar_url: str
    sidebar_config: Dict      # Настройки sidebar
    widget_config: Dict       # Настройки dashboard виджетов
```

