# Правила работы с фикстурами тестов

## Единая архитектура

Все тесты используют унифицированные фикстуры из `tests/conftest.py`.

## Основные фикстуры

### Репозитории (новая архитектура)

```python
async def test_example(
    migrated_db,
    agent_repo,        # AgentRepository
    flow_repo,         # FlowRepository
    tool_repo,         # ToolRepository
    task_repo,         # TaskRepository
    session_repo,      # SessionRepository
    user_repo,         # UserRepository
    company_repo,      # CompanyRepository
    variable_repo,     # VariableRepository
):
    # Работа через репозитории
    agent = await agent_repo.get("agent_id")
    await agent_repo.set(agent_config)
    
    user = await user_repo.get("user_id")
    company = await company_repo.get("company_id")
```

### Storage (deprecated, для совместимости)

```python
async def test_with_storage(migrated_db, storage):
    # storage - для обратной совместимости
    # РЕКОМЕНДУЕТСЯ: используй репозитории вместо storage
    ...
```

### Фабрики

```python
async def test_with_factories(agent_factory, flow_factory, tool_factory, migrator):
    # Фабрики создают живые объекты из конфигураций
    agent = await agent_factory.get_agent("agent_id")
    flow = await flow_factory.get_flow("flow_id")
    
    # Migrator для миграции
    await migrator.migrate_for_company(
        company=company,
        flows=["flow_id"],
        with_dependencies=True
    )
```

### Сервисы

```python
async def test_services(
    variables_service,    # VariablesService
    billing_service,      # BillingService
    payment_service,      # PaymentService
    auth_service,         # AuthService
):
    # Работа с переменными
    await variables_service.set_var("key", "value", is_secret=True)
    value = await variables_service.get_var("key")
    
    # Биллинг
    can_use, reason = await billing_service.can_use_resource(
        user, company, "llm:gpt-4"
    )
    await billing_service.record_usage(
        user, company, "tool:api", cost=0.5
    )
    
    # Платежи
    result = await payment_service.create_payment(
        company, user, 1000.0, provider
    )
```

### Контекст и данные

```python
async def test_with_context(
    test_context,         # Context с test_user и test_company
    test_company,         # Company с балансом
    test_user,            # User
    system_context,       # Context для системной компании
    save_test_company,    # Сохраняет test_company в БД
):
    # test_context автоматически установлен
    assert test_context.user.user_id == "test_user"
    assert test_context.active_company.company_id == "test_company"
```

### MockLLM

```python
def test_with_mock_llm(mock_llm):
    # Настрой mock ответы
    mock_llm.configure(
        tool_responses={
            "ключ в запросе": {"tool": "tool_name", "args": {"param": "value"}}
        },
        responses={
            "ключ": "Текстовый ответ"
        },
        default_response="Дефолтный ответ"
    )
```

## Вспомогательные функции (test_helpers)

### create_simple_agent (ОБНОВЛЕНО)

```python
async def test_example(test_helpers, agent_repo):
    # БЕЗ параметра storage!
    agent = await test_helpers.create_simple_agent(
        agent_id="test_agent",
        name="Test Agent",
        prompt="Промпт",
        tools=[tool1, tool2]
    )
    # Агент автоматически сохранен через agent_repo
```

### create_simple_flow (ОБНОВЛЕНО)

```python
async def test_example(test_helpers, flow_repo):
    # БЕЗ параметра storage!
    flow = await test_helpers.create_simple_flow(
        flow_id="test_flow",
        name="Test Flow",
        entry_point_agent="agent_id"
    )
    # Flow автоматически сохранен через flow_repo
```

## Создание тестовых компаний

<good_example>
from core.db.repositories.subdomain_repository import SubdomainMapping

async def test_example(company_repo, subdomain_repo):
    # Создание компании
    company = Company(company_id="test", subdomain="test", name="Test")
    await company_repo.set(company)
    
    # Создание маппинга subdomain
    subdomain_mapping = SubdomainMapping(
        subdomain=company.subdomain,
        company_id=company.company_id
    )
    await subdomain_repo.set(subdomain_mapping)
    
    # Cleanup
    await company_repo.delete(company.company_id)
    await subdomain_repo.delete(company.subdomain)
</good_example>

<bad_example>
# НЕ используй Storage напрямую
await storage.set(f"company:{company_id}", company.model_dump_json(), force_global=True)
await storage.set(f"subdomain:{subdomain}", f'"{company_id}"', force_global=True)
</bad_example>

## Правила использования

### 1. Используй фикстуры, НЕ создавай объекты

<bad_example>
from core.db.storage import Storage
from apps.agents.services.migrator import Migrator

storage = Storage()
migrator = Migrator()
</bad_example>

<good_example>
async def test_example(migrated_db, agent_repo, flow_repo, migrator):
    # Все через фикстуры
    ...
</good_example>

### 2. Используй репозитории, НЕ Storage

<bad_example>
await storage.set("agent:my_agent", agent.model_dump_json())
data = await storage.get("agent:my_agent")
</bad_example>

<good_example>
await agent_repo.set(agent)
agent = await agent_repo.get("my_agent")
</good_example>

### 3. Используй test_helpers для создания

<good_example>
# Обновлено - БЕЗ параметра storage
agent = await test_helpers.create_simple_agent(
    agent_id="test_agent",
    name="Test",
    prompt="..."
)
</good_example>

## Cleanup

Cleanup выполняется автоматически:
- Контекст очищается после каждого теста
- База данных изолирована для каждого теста
- MockLLM сбрасывает счетчики

НЕ НУЖНО делать cleanup вручную.

## 🚨 КРИТИЧНЫЕ ПРАВИЛА

1. **ВСЕГДА** используй фикстуры репозиториев
2. **НИКОГДА** не создавай Storage, Migrator, Сервисы вручную
3. **ВСЕГДА** используй test_helpers для создания тестовых данных
4. **НИКОГДА** не используй Storage для работы с моделями в тестах
5. **ВСЕГДА** используй company_repo/subdomain_repo для компаний

**Нарушение приведет к падению тестов!**
