## Создание тестовых компаний

```python
from core.db.repositories.subdomain_repository import SubdomainMapping

async def test_example(company_repo, subdomain_repo):
    company = Company(company_id="test", subdomain="test", name="Test")
    await company_repo.set(company)
    
    subdomain_mapping = SubdomainMapping(
        subdomain=company.subdomain,
        company_id=company.company_id
    )
    await subdomain_repo.set(subdomain_mapping)
    
    # Cleanup
    await company_repo.delete(company.company_id)
    await subdomain_repo.delete(company.subdomain)
```

## Правила

### 1. Все фикстуры в tests/conftest.py

<bad_example>
# tests/frontend/conftest.py
@pytest.fixture
def frontend_client():  # НЕТ! Дублирует основной conftest
    ...
</bad_example>

<good_example>
# tests/conftest.py - единственное место для фикстур
@pytest.fixture
def frontend_client():
    ...
</good_example>

### 2. Используй репозитории, НЕ Storage

<bad_example>
await storage.set("agent:my_agent", agent.model_dump_json())
</bad_example>

<good_example>
await agent_repo.set(agent)
agent = await agent_repo.get("my_agent")
</good_example>

### 3. НЕ создавай объекты вручную

<bad_example>
from core.db.storage import Storage
storage = Storage()  # НЕТ!
</bad_example>

<good_example>
async def test_example(migrated_db, agent_repo):
    # Все через фикстуры
    ...
</good_example>

## Cleanup

Cleanup выполняется автоматически:
- Контекст очищается после каждого теста
- База данных изолирована для каждого теста
- MockLLM сбрасывает счетчики

## 🚨 КРИТИЧНЫЕ ПРАВИЛА

1. **ВСЕ фикстуры** в `tests/conftest.py` (кроме `agents_service`)
2. **НИКОГДА** не создавай Storage, Migrator, Сервисы вручную
3. **ВСЕГДА** используй правильные API пути (`/frontend/api/` для JSON, `/frontend/` для HTML)
4. **ВСЕГДА** используй репозитории для работы с данными
5. **frontend_client** имеет атрибуты: `test_user`, `test_company`, `test_context`
6. **crm_client** имеет атрибуты: `test_user`, `test_company`, `test_context`, `auth_token`

**Нарушение приведет к падению тестов!**

## TaskIQ тесты

### Прямой вызов задачи (без воркера)

```python
@pytest.mark.asyncio
async def test_task_direct(taskiq_broker, note_service):
    """Вызов задачи напрямую (синхронно в тесте)"""
    from apps.crm.tasks import process_crm_attachment_task
    
    result = await process_crm_attachment_task(
        company_id="test",
        note_id="note_123",
        file_id="file_456",
        s3_key="files/test.txt",
        document_name="test.txt",
        content_type="text/plain",
    )
    assert result["status"] == "completed"
```

### E2E с воркером (subprocess)

```python
@pytest.mark.asyncio
async def test_e2e_with_worker(
    crm_client,
    note_service,
    taskiq_worker_process,  # Запускает воркер в subprocess
    taskiq_broker,
):
    """E2E тест - задача выполняется в отдельном процессе"""
    
    # Вызов через API (task.kiq() внутри сервиса)
    response = await crm_client.post(f"/crm/api/v1/notes/{note_id}/attachments", ...)
    
    # Polling вместо sleep!
    async def check_indexed():
        results = await provider.search(namespace, query)
        return results if len(results) > 0 else None
    
    result = await wait_for_condition(check_indexed, timeout=30.0, interval=2.0)
    assert result is not None
```

### wait_for_condition helper

```python
async def wait_for_condition(condition_fn, timeout: float = 30.0, interval: float = 0.5):
    """Polling вместо sleep для E2E тестов"""
    import time
    start = time.time()
    while time.time() - start < timeout:
        result = await condition_fn()
        if result:
            return result
        await asyncio.sleep(interval)
    return None
```

## CRM тесты

### Важно: company_id

В CRM тестах через API используй `crm_client.test_company.company_id`:

```python
@pytest.mark.asyncio
async def test_crm_with_api(crm_client, note_service):
    # Создание через сервис с правильным company_id
    note = await note_service.create_note(
        data,
        company_id=crm_client.test_company.company_id,  # НЕ test_context!
        user_id=crm_client.test_user.user_id
    )
    
    # API вызов
    response = await crm_client.post("/crm/api/v1/notes/...")
    
    # Получение/удаление с company_id
    await note_service.get_note(note_id, company_id=crm_client.test_company.company_id)
    await note_service.delete_note(note_id, company_id=crm_client.test_company.company_id)
```

