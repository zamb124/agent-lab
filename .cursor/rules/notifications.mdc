```

## Тестирование

### Unit тест

```python
# tests/core/websocket/test_notification_manager.py
@pytest.mark.asyncio
async def test_multiple_connections_same_user(notification_manager_instance):
    """Уведомление доходит до ВСЕХ подключений пользователя"""
    manager = notification_manager_instance
    user_id = "user_123"
    
    # 3 вкладки браузера
    await manager.connect(ws1, user_id)
    await manager.connect(ws2, user_id)
    await manager.connect(ws3, user_id)
    
    # Отправка
    notification = {"type": "test", "message": "Hello"}
    await manager.send_to_user(user_id, notification)
    
    # ВСЕ получили
    assert ws1.sent_messages == [notification]
    assert ws2.sent_messages == [notification]
    assert ws3.sent_messages == [notification]
```

### E2E тест

```python
# tests/core/websocket/test_notification_e2e.py
import websockets

@pytest.mark.asyncio
async def test_access_request_notification_flow(crm_client, crm_service):
    port = crm_service.port  # НЕ хардкодить порт!
    ws_url = f"ws://localhost:{port}/ws/notifications"
    
    async with websockets.connect(ws_url, extra_headers={
        "Cookie": f"session_id={session_id}"
    }) as ws:
        # Создать запрос доступа
        await crm_client.post("/crm/api/v1/access-requests", ...)
        
        # Получить уведомление
        message = await asyncio.wait_for(ws.recv(), timeout=5)
        notification = json.loads(message)
        
        assert notification["type"] == "access_request"
        assert notification["service"] == "crm"
```

## Frontend: Кастомизация

### Слушать события

```javascript
// Получить уведомление
document.addEventListener('platform-notification', (e) => {
  const notification = e.detail;
  console.log('Уведомление:', notification);
  
  // Кастомная обработка
  if (notification.priority === 'urgent') {
    showModalNotification(notification);
  }
  
  // Отменить стандартный toast
  e.preventDefault();
});

// WebSocket подключен
document.addEventListener('platform-ws-connected', () => {
  console.log('WebSocket active');
});

// WebSocket отключен
document.addEventListener('platform-ws-disconnected', () => {
  console.log('WebSocket lost, reconnecting...');
});
```

