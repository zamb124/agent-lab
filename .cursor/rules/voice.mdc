│   ├── vad/
│   │   ├── silero.py    # SileroVADProvider (prod)
│   │   └── mock.py      # MockVADProvider (тесты)
│   ├── stt/
│   │   ├── cloud_ru.py  # CloudRuStreamSTTProvider (prod, streaming)
│   │   └── mock.py      # MockSTTProvider (тесты)
│   └── tts/
│       ├── kokoro_local.py  # KokoroLocalTTSProvider (prod, self-hosted)
│       └── mock.py          # MockTTSProvider (тесты)
├── services/
│   ├── voice_session.py    # Оркестрация pipeline одной сессии
│   ├── voice_barge_in.py   # BargeInController
│   └── voice_chunker.py    # Разбиение текста на чанки для TTS
├── workers/
│   ├── audio_receiver.py   # WebSocket → очередь PCM
│   ├── stt_worker.py       # PCM → VAD → STT → транскрипции
│   ├── tts_worker.py       # Текст → чанки → TTS → PCM
│   └── audio_sender.py     # PCM → WebSocket клиенту
├── billing/
│   └── voice_usage.py      # VoiceUsageTracker (побайтовый учёт)
