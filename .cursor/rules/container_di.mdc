# Dependency Injection через Container в монорепозитории

## Обновлено для новой архитектуры

### Структура контейнеров

```
core/container/
└── base.py              # BaseContainer (storage, auth_service, s3_factory)

apps/agents/container.py # AgentsContainer(BaseContainer)
```

### BaseContainer (в core)

```python
# core/container/base.py
class BaseContainer:
    """Базовый контейнер с общими сервисами"""
    
    def __init__(self, db_url: Optional[str] = None):
        self.db_url = db_url
        self._storage = None
        self._auth_service = None
        self._s3_factory = None
    
    def __getattr__(self, name):
        if name == 'storage':
            if self._storage is None:
                from core.db.storage import Storage
                from core.context import get_context
                self._storage = Storage(db_url=self.db_url, get_context_func=get_context)
            return self._storage
        
        if name == 'auth_service':
            if self._auth_service is None:
                from core.identity.auth_service import AuthService
                self._auth_service = AuthService(self.storage)
            return self._auth_service
        
        raise AttributeError(f"'{self.__class__.__name__}' object has no attribute '{name}'")
```

### AgentsContainer (в apps/agents)

```python
# apps/agents/container.py
from core.container.base import BaseContainer

class AgentsContainer(BaseContainer):
    """Контейнер для сервиса агентов"""
    
    def __init__(self, service_db_url, shared_db_url):
        super().__init__(db_url=service_db_url)
        self.shared_db_url = shared_db_url
        self._shared_storage = None
        self._variables_service = None
        self._agent_repository = None
    
    def __getattr__(self, name):
        if name == 'shared_storage':
            if self._shared_storage is None:
                from core.db.storage import Storage
                from core.context import get_context
                self._shared_storage = Storage(db_url=self.shared_db_url, get_context_func=get_context)
            return self._shared_storage
        
        if name == 'variables_service':
            if self._variables_service is None:
                from core.variables.service import VariablesService
                self._variables_service = VariablesService(self.storage)
                return self._variables_service
        
        if name == 'agent_repository':
            if self._agent_repository is None:
                from apps.agents.db.repositories import AgentRepository
                self._agent_repository = AgentRepository(storage=self.storage)
            return self._agent_repository
        
        return super().__getattr__(name)  # Делегируем BaseContainer

# Глобальный контейнер сервиса
_agents_container = None

def get_agents_container() -> AgentsContainer:
    global _agents_container
    if _agents_container is None:
        raise RuntimeError("AgentsContainer не инициализирован!")
    return _agents_container

def set_agents_container(container: AgentsContainer):
    global _agents_container
    _agents_container = container

# Алиас для кода внутри apps/agents
get_container = get_agents_container
```

### Использование

<good_example>
# В apps/agents/services/agent_factory.py
from apps.agents.container import get_agents_container

class AgentFactory:
    def __init__(self, agent_repository):
        self.agent_repository = agent_repository
    
    async def get_agent(self, agent_id):
        # Используем репозиторий из контейнера через конструктор
        config = await self.agent_repository.get(agent_id)
        
        # Или получаем другие сервисы из контейнера
        tool_factory = get_agents_container().tool_factory
</good_example>

<bad_example>
# НЕТ прямых импортов сущностей контейнера!
from apps.agents.db.repositories.agent_repository import AgentRepository  # НЕТ!

# НЕТ прямого создания!
repo = AgentRepository()  # НЕТ!

# НЕТ импорта из core в apps
from core.container import get_container  # НЕТ! Используй get_agents_container()
</bad_example>

## КРИТИЧНО

1. **core.container.BaseContainer** - только базовые сервисы
2. **apps.{service}.container.{Service}Container** - наследует BaseContainer
3. Используй **get_agents_container()** в apps/agents, НЕ get_container() из core
4. **Ленивая инициализация** через __getattr__
5. **Service БД + Shared БД** в контейнере
6. **НЕТ прямых импортов** сущностей контейнера
