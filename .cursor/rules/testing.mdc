### Тест streaming

```python
@pytest.mark.real_taskiq
class TestStreaming:
    @pytest.mark.asyncio
    async def test_pubsub(self, redis_client, unique_id):
        from apps.agents.src.streaming import Emitter, EventSubscriber
        
        await redis_client.connect()
        
        task_id = f"task-{unique_id}"
        context_id = f"ctx-{unique_id}"
        
        state = ExecutionState.create(
            task_id=task_id,
            context_id=context_id,
            user_id=f"user-{unique_id}"
        )
        
        emitter = Emitter(redis_client, state)
        subscriber = EventSubscriber(redis_client)
        
        # Публикуем событие
        await emitter.emit_text("Hello")
        
        # Подписываемся и читаем
        events = []
        async for event in subscriber.subscribe(task_id):
            events.append(event)
            if len(events) >= 1:
                break
        
        assert len(events) == 1
        assert events[0].kind == "task-artifact-update"
        
        await redis_client.close()
```

