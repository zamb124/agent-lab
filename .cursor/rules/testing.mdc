```python
class TestInterrupt:
    @pytest.mark.asyncio
    async def test_interrupt_resume(self, client, mock_llm_with_queue, unique_id):
        # Первый запрос - interrupt
        mock_llm_with_queue([
            {"type": "tool_call", "tool": "ask_user", "args": {"question": "Какой склад?"}}
        ])
        
        context_id = f"interrupt-{unique_id}"
        response1 = await client.post(
            "/agents/example_react",
            json={
                "jsonrpc": "2.0",
                "method": "message/send",
                "params": {
                    "message": {
                        "messageId": f"msg1-{unique_id}",
                        "role": "user",
                        "parts": [{"kind": "text", "text": "Start"}],
                        "contextId": context_id
                    }
                }
            }
        )
        
        assert response1.status_code == 200
        task1 = response1.json()["result"]
        assert task1["status"]["state"] == "input-required"
        
        # Resume с ответом
        mock_llm_with_queue(["Спасибо, продолжаю работу"])
        
        response2 = await client.post(
            "/agents/example_react",
            json={
                "jsonrpc": "2.0",
                "method": "message/send",
                "params": {
                    "message": {
                        "messageId": f"msg2-{unique_id}",
                        "role": "user",
                        "parts": [{"kind": "text", "text": "Склад Большие"}],
                        "contextId": context_id
                    }
                }
            }
        )
        
        assert response2.status_code == 200
        task2 = response2.json()["result"]
        assert task2["status"]["state"] == "completed"
