### Auth фикстуры (tests/fixtures/auth.py)

**ВАЖНО:** Используй эти фикстуры для тестирования доступа и прав!

| Фикстура | Scope | Компания | Роль | Назначение |
|----------|-------|----------|------|------------|
| `auth_headers_system` | function | `system` | owner, admin | Основной пользователь системной компании |
| `auth_headers_system_user2` | function | `system` | member | Второй пользователь системной компании (для проверки доступа внутри компании) |
| `auth_headers_company2` | function | `company2` | owner, admin | Пользователь из другой компании (для cross-company тестов) |
| `auth_headers_company2_user2` | function | `company2` | member | Второй пользователь из другой компании |

**Сценарии использования:**

```python
# 1. Базовый тест с авторизацией
async def test_create_entity(crm_client, auth_headers_system, unique_id):
    response = await crm_client.post(
        "/crm/api/v1/entities/",
        json={"entity_type": "note", "name": f"Test {unique_id}"},
        headers=auth_headers_system  # Авторизованный запрос
    )
    assert response.status_code == 200

# 2. Тест доступа внутри компании (same company access)
async def test_same_company_access(crm_client, auth_headers_system, auth_headers_system_user2, unique_id):
    # User1 создает entity
    response1 = await crm_client.post(
        "/crm/api/v1/entities/",
        json={"entity_type": "note", "name": f"Test {unique_id}"},
        headers=auth_headers_system
    )
    entity_id = response1.json()["entity_id"]
    
    # User2 из той же компании пытается получить доступ
    response2 = await crm_client.get(
        f"/crm/api/v1/entities/{entity_id}",
        headers=auth_headers_system_user2
    )
    # Ожидаем 200 если есть namespace access или 403 если нет

# 3. Тест cross-company доступа (public grants)
async def test_public_access(crm_client, auth_headers_system, auth_headers_company2, unique_id):
    # System user создает entity
    response1 = await crm_client.post(
        "/crm/api/v1/entities/",
        json={"entity_type": "note", "name": f"Public Note {unique_id}"},
        headers=auth_headers_system
    )
    entity_id = response1.json()["entity_id"]
    
    # Делаем публичной
    await crm_client.post(
        f"/crm/api/v1/entities/{entity_id}/grants/public",
        headers=auth_headers_system
    )
    
    # User из другой компании получает доступ
    response2 = await crm_client.get(
        f"/crm/api/v1/entities/{entity_id}",
        headers=auth_headers_company2  # Другая компания
    )
    assert response2.status_code == 200

# 4. Тест user-specific grants
async def test_user_grant(crm_client, auth_headers_system, auth_headers_company2, unique_id):
    # System user создает entity
    response1 = await crm_client.post(
        "/crm/api/v1/entities/",
        json={"entity_type": "task", "name": f"Task {unique_id}"},
        headers=auth_headers_system
    )
    entity_id = response1.json()["entity_id"]
    
    # Шарим конкретному пользователю из company2
    # Сначала получаем user_id из auth_headers_company2 (через токен)
    from core.utils.tokens import get_token_service
    token_service = get_token_service()
    token = auth_headers_company2["Authorization"].replace("Bearer ", "")
    payload = token_service.decode_token(token)
    user_id = payload["user_id"]
    
    # Создаем grant для этого user
    await crm_client.post(
        f"/crm/api/v1/entities/{entity_id}/grants/user",
        json={"user_id": user_id, "role": "editor"},
        headers=auth_headers_system
    )
    
    # User из company2 получает доступ
    response2 = await crm_client.get(
        f"/crm/api/v1/entities/{entity_id}",
        headers=auth_headers_company2
    )
    assert response2.status_code == 200

# 5. Тест отказа в доступе (403)
async def test_access_denied(crm_client, auth_headers_system, auth_headers_company2, unique_id):
    # System user создает private entity
    response1 = await crm_client.post(
        "/crm/api/v1/entities/",
        json={"entity_type": "note", "name": f"Private {unique_id}"},
        headers=auth_headers_system
    )
    entity_id = response1.json()["entity_id"]
    
    # User из другой компании НЕ может получить доступ
    response2 = await crm_client.get(
        f"/crm/api/v1/entities/{entity_id}",
        headers=auth_headers_company2
    )
    assert response2.status_code == 403
```

**Под капотом (как работают auth фикстуры):**

1. **Создают компании** через `Company` модель и сохраняют в `company_repository`
2. **Создают пользователей** через `User` модель с привязкой к компаниям
3. **Генерируют JWT токены** через `get_token_service().create_token(user_id, company_id)`
4. **Возвращают заголовки** в формате `{"Authorization": "Bearer <token>"}`

**Scope: `session` для токенов, `function` для headers**
- Токены создаются один раз на всю сессию тестов
- Headers создаются для каждого теста (но используют общий токен)
- Это обеспечивает баланс между производительностью и изоляцией

