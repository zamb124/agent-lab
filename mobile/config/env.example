# Скопировать в mobile/.env (не коммитить).
# Канонический HTTPS-URL манифеста PWA (тот же origin, что и start_url в манифесте).
PWA_MANIFEST_URL=https://humanitec.ru/manifest.json

# Опционально: для скриптов проверки перед сборкой
PWA_ORIGIN=https://humanitec.ru

# Lighthouse CI (mobile/scripts/run-lighthouse-ci.sh, GitHub Actions)
# PWA_LIGHTHOUSE_URL=https://humanitec.ru/

# После первого bubblewrap init — путь к каталогу проекта TWA (локально)
# TWA_PROJECT_DIR=android/twa-project
