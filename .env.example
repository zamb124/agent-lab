# Скопируй в .env и заполни значениями
# cp .env.example .env

# === DATABASE (сервисные БД + redis) ===
# Важно: любая строка DATABASE__* здесь перекрывает conf.json. Для make app + docker-compose-dev.yaml
# должны совпадать POSTGRES_USER / POSTGRES_PASSWORD / порт (54321 с хоста). Не копируйте старый шаблон 5432/agent_user.
# Если все URL в conf.json уже верны — закомментируйте блок или удалите .env.
DATABASE__CHECKPOINTER_URL=postgresql://platform_user:admin@localhost:54321/platform_shared
DATABASE__SHARED_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_shared
DATABASE__FLOWS_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_agents
DATABASE__CRM_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_crm
DATABASE__SYNC_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_sync
DATABASE__RAG_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_rag
DATABASE__OFFICE_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_office
DATABASE__TRACING_URL=postgresql+asyncpg://platform_user:admin@localhost:54321/platform_tracing
DATABASE__REDIS_URL=redis://localhost:63791/0

# === SERVER ===
SERVER__ENV=local
SERVER__DEBUG=true
SERVER__FLOWS_SERVICE_URL=http://localhost:8001

# === RAG (pgvector) ===
# Эмбеддинги и vector_documents — DATABASE__RAG_URL

# === LLM (OpenRouter) ===
LLM__OPENROUTER__API_KEY=your_openrouter_api_key

# === AUTH ===
AUTH__SECRET_KEY=your_secret_key
AUTH__JWT_SECRET_KEY=your_jwt_secret_key
# Sign in with Apple (локально): одна строка, переводы строк в PEM как \n
# Плюс в conf.json / conf.local.json: auth.providers.apple (client_id, apple_team_id, apple_key_id)
# В Apple Developer для теста с lvh.me добавь Return URL: http://lvh.me:8002/auth/callback/apple
# AUTH__PROVIDERS__APPLE__APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----
# Демо-вход: пароль можно задать в conf.json (auth.demo.password), либо переопределить через ENV:
# AUTH__DEMO__PASSWORD=...

# === Documents / OnlyOffice (BFF apps/office) — JWT Document Server = OFFICE__JWT_SECRET ===
# OFFICE__DOCUMENT_SERVER_PUBLIC_URL=http://localhost:8088
# OFFICE__JWT_SECRET=...  # тот же секрет, что JWT_SECRET в onlyoffice/documentserver
# OFFICE__CALLBACK_PUBLIC_BASE_URL=http://localhost:8008  # URL BFF, доступный с контейнера DS
# Внешний вид: conf.json — editor_customization; образ onlyoffice/documentserver (CE) — без trial-полосы DE, шапка чаще ONLYOFFICE; кастомное logo из JWT в CE может не применяться (см. office.mdc)

# === S3 ===
S3__ENABLED=false

# === TELEGRAM ===
# TELEGRAM__BOTS__YOUR_BOT=bot_token
