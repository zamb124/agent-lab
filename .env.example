# Скопируй в .env и заполни значениями
# cp .env.example .env

# === DATABASE (пять сервисных БД + redis) ===
DATABASE__CHECKPOINTER_URL=postgresql://agent_user:agent_password@localhost:5432/agent_platform
DATABASE__SHARED_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/platform_shared
DATABASE__FLOWS_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/platform_agents
DATABASE__CRM_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/platform_crm
DATABASE__SYNC_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/platform_sync
DATABASE__RAG_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/platform_rag
DATABASE__REDIS_URL=redis://localhost:8099

# === SERVER ===
SERVER__ENV=local
SERVER__DEBUG=true
SERVER__FLOWS_SERVICE_URL=http://localhost:8001

# === RAG (pgvector) ===
# Эмбеддинги и vector_documents — DATABASE__RAG_URL

# === LLM (OpenRouter) ===
LLM__OPENROUTER__API_KEY=your_openrouter_api_key

# === AUTH ===
AUTH__SECRET_KEY=your_secret_key
AUTH__JWT_SECRET_KEY=your_jwt_secret_key
# Sign in with Apple (локально): одна строка, переводы строк в PEM как \n
# Плюс в conf.json / conf.local.json: auth.providers.apple (client_id, apple_team_id, apple_key_id)
# В Apple Developer для теста с lvh.me добавь Return URL: http://lvh.me:8002/auth/callback/apple
# AUTH__PROVIDERS__APPLE__APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----

# === S3 ===
S3__ENABLED=false

# === TELEGRAM ===
# TELEGRAM__BOTS__YOUR_BOT=bot_token
