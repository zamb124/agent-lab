# Скопируй в .env и заполни значениями
# cp .env.example .env

# === DATABASE ===
DATABASE__URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/agents_db
DATABASE__CHECKPOINTER_URL=postgresql://agent_user:agent_password@localhost:5432/agents_db
DATABASE__SHARED_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/shared_db
DATABASE__AGENTS_DB_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/agents_db
DATABASE__CRM_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/crm_db
DATABASE__REDIS_URL=redis://localhost:8099

# === SERVER ===
SERVER__ENV=local
SERVER__DEBUG=true
SERVER__AGENTS_SERVICE_URL=http://localhost:8001

# === RAG (pgvector) ===
# pgvector использует основное DATABASE__URL подключение

# === LLM (OpenRouter) ===
LLM__OPENROUTER__API_KEY=your_openrouter_api_key

# === AUTH ===
AUTH__SECRET_KEY=your_secret_key
AUTH__JWT_SECRET_KEY=your_jwt_secret_key

# === S3 ===
S3__ENABLED=false

# === TELEGRAM ===
# TELEGRAM__BOTS__YOUR_BOT=bot_token
