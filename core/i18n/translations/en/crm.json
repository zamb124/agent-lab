        "templateIcon": "Icon for navigation: shown on template cards and selectors. Pick a symbol that matches the domain.",
        "typeId": "Technical type id. Stable and unique within the template. Prefer snake_case, e.g. lead, candidate_profile, incident_note.",
        "typeName": "Display name for the type. Users see it in the UI when working with entities and cards.",
        "parentType": "Base behaviour. Usually note for notes and task for tasks. Choosing another template type as parent builds specialized subtypes.",
        "typeIcon": "Type icon in lists, cards and hints. Pick a marker that stays recognizable in dense UI.",
        "typeColor": "Optional colour accent. Leave empty if not needed; if set, keep palette consistent with your team.",
        "weight": "Weight for ranking in analytics. 1.0 is neutral; higher boosts priority, lower reduces it.",
        "flagIsEvent": "When on, entities of this type are treated as time events (meeting, call, incident) and can drive timeline scenarios.",
        "flagCheckDuplicates": "When on, the system checks duplicates when extracting/creating entities of this type. Turn off only if duplicates are allowed.",
        "flagContextAnchor": "Deals, leads and similar types: notes can be grouped around them (context on the graph).",
        "typeDescription": "Team-facing explanation: what this type stores, required attributes, which processes use it.",
        "typePrompt": "Prompt for AI extraction: which facts to find, field names, and what is mandatory.",
        "namespaces": "Restrict where the type applies. Only selected namespaces; keeps domains clean.",
        "requiredFields": "Required attributes; the record is incomplete without them. Use for critical data per object.",
        "optionalFields": "Extra attributes for richer context. Not required on create but improve analytics and search.",
        "fieldKey": "System field key (snake_case). Used in JSON/integrations and must stay stable. Example: candidate_name, deal_stage, severity.",
