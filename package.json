{
  "name": "agent-lab",
  "private": true,
  "scripts": {
    "test:core-unit": "vitest run --config vitest.config.mjs --coverage",
    "test:core-unit:fast": "vitest run --config vitest.config.mjs",
    "test:core-unit:watch": "vitest --config vitest.config.mjs",
    "test:core-browser": "web-test-runner --config web-test-runner.config.mjs",
    "test:core-browser:watch": "web-test-runner --config web-test-runner.config.mjs --watch",
    "test:core": "npm run test:core-unit && npm run test:core-browser",
    "test:ui-components": "web-test-runner --config web-test-runner.config.mjs",
    "test:ui-components:watch": "web-test-runner --config web-test-runner.config.mjs --watch",
    "build:codemirror": "node scripts/build_codemirror_bundle.mjs"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@open-wc/testing": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@web/dev-server-import-maps": "^0.2.1",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.0",
    "esbuild": "^0.28.0",
    "lit": "^3.2.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "3d-force-graph": "^1.79.1"
  }
}
