# Базовый образ платформы: Python 3.14t, free-threaded venv, apt-runtime, всё
# тяжёлое (torch CPU + ML stack: sentence-transformers, transformers,
# pyannote-audio, silero, nvidia-cu*, tiktoken). Главный Dockerfile стартует
# `FROM ghcr.io/<owner>/agent-lab-base:latest` и поверх делает только COPY кода →
# CI build за минуты вместо часа.
#
# Источник правды для production — GHA workflow `.github/workflows/build-base.yml`:
#   - Триггер: push в main с изменением pyproject.toml / uv.lock / Dockerfile.base
#   - Триггер: workflow_dispatch (Actions UI → Build Base Image → Run workflow)
#   - Push в ghcr.io/<owner>/agent-lab-base:latest + :<sha>
#
# Локальный fallback для отладки (Docker Hub):
#   make base
#
# Когда пересобирать: при изменении ЛЮБОЙ зависимости в группах core / agents /
# worker-base / rag-worker / crm / rag / sync / browser в pyproject.toml.
# Группа `dev` в base НЕ ставится (нужна только для test runner).

FROM ghcr.io/astral-sh/uv:bookworm-slim

WORKDIR /app

ARG NODE_MAJOR=24
ARG GO_VERSION=1.26.1
ARG DOTNET_CHANNEL=10.0

# Free-threaded CPython (PEP 779). Default GIL=0 для всех процессов в этом образе.
ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
ENV UV_PYTHON_PREFERENCE=only-managed
ENV PYTHON_GIL=0

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    gnupg \
    build-essential \
    pkg-config \
    libcairo2-dev \
    libpq-dev \
    ffmpeg \
    tesseract-ocr \
    tesseract-ocr-rus \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    antiword \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

RUN uv python install 3.14t && uv python pin 3.14t

RUN mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
      | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
      > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) go_arch="amd64" ;; \
      arm64) go_arch="arm64" ;; \
      *) echo "Unsupported architecture for Go: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz; \
    rm -rf /usr/local/go; \
    tar -C /usr/local -xzf /tmp/go.tgz; \
    ln -sf /usr/local/go/bin/go /usr/local/bin/go; \
    ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt; \
    rm -f /tmp/go.tgz; \
    node --version; \
    go version

ENV DOTNET_ROOT=/usr/share/dotnet
ENV PATH="${DOTNET_ROOT}:${PATH}"
RUN curl -fsSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh && \
    bash /tmp/dotnet-install.sh --channel "${DOTNET_CHANNEL}" --quality ga --install-dir "${DOTNET_ROOT}" && \
    ln -sf "${DOTNET_ROOT}/dotnet" /usr/local/bin/dotnet && \
    rm -f /tmp/dotnet-install.sh && \
    dotnet --version

# Копируем только файлы зависимостей
COPY pyproject.toml uv.lock README.md ./

# Базовый venv для уровня base-image (cp314t free-threaded). Наследуется в child images.
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="/opt/venv/bin:${PATH}"
ENV UV_HTTP_TIMEOUT=600
RUN uv venv --python 3.14t "${VIRTUAL_ENV}"

# Torch только для CPU (экономит ~2-3 GB по сравнению с CUDA-вариантом).
# Ставим ДО основных deps чтобы транзитивный CUDA-torch из ML-deps его не перетёр.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --python "${VIRTUAL_ENV}/bin/python" torch torchvision \
    --index-url https://download.pytorch.org/whl/cpu

# Все production deps платформы (строго по uv.lock), без `dev`. После сборки
# venv `/opt/venv` содержит весь Python-стек: FastAPI, Granian, asyncpg, redis,
# taskiq, sentence-transformers, transformers, pyannote-audio, silero, livekit,
# playwright и т.д. Main Dockerfile уже ничего не доставляет — только COPY кода.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv export --frozen --no-dev --no-default-groups \
        --group core \
        --group agents \
        --group worker-base \
        --group rag-worker \
        --group crm \
        --group rag \
        --group sync \
        --group browser \
        --no-annotate --no-header --no-emit-project \
        -o /tmp/requirements.txt && \
    uv pip install --python "${VIRTUAL_ENV}/bin/python" -r /tmp/requirements.txt
