# Test Dockerfile — Python 3.13, единая версия для всех окружений.

FROM python:3.13-slim AS base-test

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    ffmpeg \
    tesseract-ocr \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY pyproject.toml README.md ./

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system \
        --group core \
        --group agents \
        --group worker-base \
        --group rag \
        --group crm \
        --group sync \
        --group dev

# RAG Worker stage для тестов (минимальный образ; сборка: --target rag-worker)
FROM base-test AS rag-worker

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system --group rag-worker

COPY core/ ./core/
COPY apps/rag_worker/ ./apps/rag_worker/
COPY apps/__init__.py ./apps/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TESTING=true

CMD ["taskiq", "worker", "apps.rag_worker.worker:broker", "--workers", "1"]

# Полный образ для pytest и worker/scheduler (последний stage = default при сборке без --target)
FROM base-test AS default

COPY . .

RUN mkdir -p /app/test-results /app/htmlcov && \
    chmod 777 /app/test-results /app/htmlcov

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TESTING=true

CMD ["python", "-m", "pytest", "tests/", "-v"]
