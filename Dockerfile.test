# Test Dockerfile — Python 3.13, единая версия для всех окружений.

FROM python:3.13-slim AS base-test

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    ffmpeg \
    tesseract-ocr \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    antiword \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY pyproject.toml uv.lock README.md ./

RUN --mount=type=cache,target=/root/.cache/uv \
    uv export --frozen --no-default-groups \
        --group core \
        --group agents \
        --group worker-base \
        --group rag \
        --group crm \
        --group sync \
        --group dev \
        --no-annotate --no-header --no-emit-project \
        -o /tmp/requirements.txt && \
    uv pip install --system -r /tmp/requirements.txt

# RAG Worker stage для тестов (минимальный образ; сборка: --target rag-worker)
FROM base-test AS rag-worker

RUN --mount=type=cache,target=/root/.cache/uv \
    uv export --frozen --no-default-groups --only-group rag-worker \
        --no-annotate --no-header --no-emit-project \
        -o /tmp/rag-worker-requirements.txt && \
    uv pip install --system -r /tmp/rag-worker-requirements.txt

COPY core/ ./core/
COPY apps/rag/ ./apps/rag/
COPY apps/rag_worker/ ./apps/rag_worker/
COPY apps/__init__.py ./apps/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TESTING=true

CMD ["taskiq", "worker", "apps.rag_worker.worker:worker_app", "--workers", "1"]

# Полный образ для pytest и worker/scheduler (последний stage = default при сборке без --target)
FROM base-test AS default

COPY . .

RUN mkdir -p /app/test-results /app/htmlcov && \
    chmod 777 /app/test-results /app/htmlcov

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TESTING=true

CMD ["python", "-m", "pytest", "tests/", "-v"]
