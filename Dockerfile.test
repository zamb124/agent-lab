# Test runner и rag-worker для docker-compose-test.
# Базовый venv — agent-lab-test-base (prod deps + dev group), см. Dockerfile.test.base.

ARG TEST_BASE_IMAGE=ghcr.io/zamb124/agent-lab-test-base:latest
ARG BASE_IMAGE=ghcr.io/zamb124/agent-lab-base:latest

FROM ${BASE_IMAGE} AS rag-worker

COPY core/ ./core/
COPY apps/rag/ ./apps/rag/
COPY apps/rag_worker/ ./apps/rag_worker/
COPY apps/__init__.py ./apps/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TESTING=true

CMD ["taskiq", "worker", "apps.rag_worker.worker:worker_app", "--workers", "1"]

FROM ${TEST_BASE_IMAGE} AS default

COPY . .

RUN mkdir -p /app/test-results /app/htmlcov && \
    chmod 777 /app/test-results /app/htmlcov

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV TESTING=true

CMD ["python", "-m", "pytest", "tests/", "-v"]
